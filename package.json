{
  "name": "tqq",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "init": "node init.js",
    "scrape": "node services/scrape.js",
    "epub": "node services/toEpub.js",
    "epub:webtoon": "node services/toEpub.js --webtoon",
    "chapters": "node services/getChapters.js",
    "cbz": "node services/toCbz.js",
    "compress": "node services/compressImg.js",
    "start": "node run.js",
    "ui": "node server/index.js",
    "ui:local": "node server/index.js --local",
    "ui:stop": "lsof -ti :3000 | xargs kill -9 2>/dev/null || true",
    "export": "node export-cbz.js",
    "tunnel": "echo '🚇 Tunneling port '${PORT:-3000}'...' && cloudflared tunnel --url http://localhost:${PORT:-3000}",
    "tunnel:stop": "pkill cloudflared 2>/dev/null && echo '✅ Tunnel stopped' || echo 'No tunnel running'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "cheerio": "^1.2.0",
    "express": "^4.22.2",
    "puppeteer": "^24.43.0",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.34.5"
  }
}
